---
import '../styles/global.css';
export let title = 'Marcos Muñoz — Desarrollo Web y Formateo de PC en San Bernardo';
export let description = 'Desarrollador web en San Bernardo, Chile. Creo tiendas online, páginas web profesionales y ofrezco formateo de Windows con respaldo de información.';
export let urlWeb = 'https://portafoliomarcosm.netlify.app/';
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/icono-portafolio2.svg">
  <link rel="canonical" href={urlWeb} />

  <!-- Open Graph / Twitter -->
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="es_CL" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={urlWeb} />
  <meta property="og:image" content={`${urlWeb}/images/portafolioWeb.webp`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${urlWeb}/images/portafolioWeb.webp`} />

  <!-- Meta tags SEO -->
  <meta name="description" content={description} />
  <meta name="author" content="Marcos Muñoz" />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Marcos Muñoz",
      "jobTitle": "Desarrollador Web",
      "url": "{urlWeb}",
      "image": "{urlWeb}/images/portafolioWeb.webp",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "San Bernardo",
        "addressCountry": "CL"
      },
      "sameAs": [
        "https://github.com/fronux2",
        "https://www.linkedin.com/in/marcos-mu%C3%B1oz-gonzalez-a32888270/"
      ]
    }
  </script>
</head>
<body class="bg-gray-50 text-gray-800 dark:bg-gray-900 dark:text-gray-100 font-sans antialiased">
  <div class="min-h-screen flex flex-col">
    <slot />
    
    <!-- Footer -->
    <footer class="mt-auto py-6 bg-gradient-to-b from-gray-800 to-slate-900 text-white">
      <div class="container mx-auto px-4 text-center">
        <p>© 2025 Marcos Muñoz, bless.</p>
      </div>
    </footer>
  </div>
</body>
</html>
